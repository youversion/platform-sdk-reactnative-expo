{
  "name": "@youversion/platform-react-native-expo-ui",
  "version": "0.9.0",
  "description": "YouVersion Platform Bible components for React Native (Expo) — reader, verse cards, Verse of the Day, theming, and native sheets.",
  "keywords": [
    "youversion",
    "bible",
    "scripture",
    "expo",
    "react-native",
    "expo-dom-components"
  ],
  "homepage": "https://github.com/youversion/platform-sdk-reactnative-expo#readme",
  "bugs": "https://github.com/youversion/platform-sdk-reactnative-expo/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youversion/platform-sdk-reactnative-expo.git",
    "directory": "packages/ui"
  },
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "main": "build/index.js",
    "types": "build/index.d.ts"
  },
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "expo-module prepublishOnly && node scripts/stamp-sdk-version.cjs"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^react$": "<rootDir>/../../node_modules/react",
      "^react/(.*)$": "<rootDir>/../../node_modules/react/$1",
      "^react-dom$": "<rootDir>/../../node_modules/react-dom",
      "^react-dom/(.*)$": "<rootDir>/../../node_modules/react-dom/$1"
    },
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|expo-.*|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|jest-expo|@rn-primitives))",
      "/node_modules/react-native-reanimated/plugin/"
    ]
  },
  "dependencies": {
    "@radix-ui/react-use-controllable-state": "1.2.2",
    "@rn-primitives/portal": "1.4.0",
    "@youversion/platform-react-native-expo-core": "workspace:*",
    "@youversion/platform-react-ui": "^2.2.0",
    "expo-localization": "~56.0.6",
    "i18next": "^26.3.1",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.13"
  },
  "peerDependencies": {
    "@expo/dom-webview": ">=56.0.0 <57.0.0",
    "@gorhom/bottom-sheet": ">=5.0.0",
    "expo": ">=56.0.0 <57.0.0",
    "expo-web-browser": ">=56.0.0 <57.0.0",
    "react": ">=19.0.0 <20.0.0",
    "react-dom": ">=19.0.0 <20.0.0",
    "react-native": ">=0.83.0",
    "react-native-gesture-handler": ">=2.16.1",
    "react-native-reanimated": ">=3.16.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-svg": ">=15.15.0",
    "react-native-webview": ">=13.13.0",
    "react-native-worklets": ">=0.8.0"
  },
  "peerDependenciesMeta": {
    "react-native-webview": {
      "optional": true
    },
    "react-native-worklets": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "babel-preset-expo": "56.0.0",
    "expo-module-scripts": "56.0.3",
    "jest": "29.7.0",
    "jest-expo": "56.0.0",
    "react-test-renderer": "19.2.5"
  }
}
