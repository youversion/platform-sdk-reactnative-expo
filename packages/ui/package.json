{
  "name": "@youversion/platform-react-native-expo",
  "version": "0.0.1",
  "description": "React Native Expo components for Bible applications, powered by the YouVersion Web SDK.",
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youversion/platform-sdk-reactnative-expo.git"
  },
  "homepage": "https://github.com/youversion/platform-sdk-reactnative-expo#readme",
  "bugs": {
    "url": "https://github.com/youversion/platform-sdk-reactnative-expo/issues"
  },
  "keywords": [
    "react-native",
    "expo",
    "youversion",
    "bible",
    "sdk"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rn-primitives/portal": "^1.4.0",
    "@youversion/platform-react-hooks": "^1.24.0",
    "@youversion/platform-react-ui": "^1.28.0",
    "zustand": "^5.0.13"
  },
  "peerDependencies": {
    "@gorhom/bottom-sheet": ">=5.0.0",
    "expo": ">=55.0.0 <56.0.0",
    "expo-secure-store": ">=55.0.0 <56.0.0",
    "react": ">=19.0.0 <20.0.0",
    "react-dom": ">=19.0.0 <20.0.0",
    "react-native": ">=0.83.0",
    "react-native-gesture-handler": ">=2.16.1",
    "react-native-mmkv": "^4.0.0",
    "react-native-nitro-modules": ">=0.35.0 <0.37.0",
    "react-native-reanimated": ">=3.16.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-webview": ">=13.13.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "expo-secure-store": "^55.0.13",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-test-renderer": "19.2.5"
  }
}
