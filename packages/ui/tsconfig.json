{
  "extends": "expo-module-scripts/tsconfig.base",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build",
    // Source imports ./i18n/locales/en.json. The expo-module-scripts base does
    // not enable this, so set it explicitly or the build cannot resolve the JSON.
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/__mocks__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test-utils/**",
    "src/**/test-utils/**"
  ]
}
