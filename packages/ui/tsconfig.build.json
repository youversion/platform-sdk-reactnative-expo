{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    // Source imports ./i18n/locales/en.json. Set this explicitly so the build
    // does not rely on it being implied by moduleResolution: bundler.
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": [
    "src/__tests__/**",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test-utils/**",
    "src/**/test-utils/**"
  ]
}
