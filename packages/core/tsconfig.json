{
  "extends": "expo-module-scripts/tsconfig.base",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build"
  },
  "include": ["src"],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/__mocks__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test-utils/**",
    "src/**/test-utils/**"
  ]
}
