{
  "name": "@youversion/platform-react-native-expo-core",
  "version": "1.0.0",
  "description": "YouVersion Platform core for React Native (Expo) — installation id, optional PKCE auth, and storage.",
  "keywords": [
    "youversion",
    "bible",
    "expo",
    "react-native",
    "oauth",
    "pkce"
  ],
  "homepage": "https://github.com/youversion/platform-sdk-reactnative-expo#readme",
  "bugs": "https://github.com/youversion/platform-sdk-reactnative-expo/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youversion/platform-sdk-reactnative-expo.git",
    "directory": "packages/core"
  },
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "expo-module prepublishOnly"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^react$": "<rootDir>/../../node_modules/react",
      "^react/(.*)$": "<rootDir>/../../node_modules/react/$1",
      "^react-dom$": "<rootDir>/../../node_modules/react-dom",
      "^react-dom/(.*)$": "<rootDir>/../../node_modules/react-dom/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/index.ts",
      "!src/**/*.d.ts",
      "!src/**/types.ts",
      "!src/**/constants.ts"
    ],
    "coverageReporters": [
      "json",
      "lcov",
      "text",
      "clover",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "lines": 90
      }
    }
  },
  "peerDependencies": {
    "expo": ">=56.0.0 <57.0.0",
    "expo-application": ">=56.0.0 <57.0.0",
    "expo-crypto": ">=56.0.0 <57.0.0",
    "expo-secure-store": ">=56.0.0 <57.0.0",
    "expo-web-browser": ">=56.0.0 <57.0.0",
    "react": ">=19.0.0 <20.0.0",
    "react-native": ">=0.85.0",
    "react-native-mmkv": ">=4.0.0 <5.0.0",
    "react-native-nitro-modules": ">=0.35.0 <0.37.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.14",
    "expo-module-scripts": "56.0.3",
    "jest": "29.7.0",
    "jest-expo": "56.0.5"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
