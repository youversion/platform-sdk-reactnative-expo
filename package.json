{
  "name": "platform-sdk-reactnative-expo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "expo": "56.0.12"
    }
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "9",
    "eslint-config-expo": "56.0.4",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.3",
    "turbo": "2.9.7",
    "typescript": "6.0.3"
  }
}
