{
  "name": "platform-sdk-reactnative-expo",
  "private": true,
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/youversion/platform-sdk-reactnative-expo.git"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "clean:cache": "bash scripts/clear-cache.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:native-i18n": "node scripts/test-native-i18n-eslint.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:locale-parity": "node scripts/check-locale-parity.mjs",
    "check:locale-json-guard": "node scripts/check-locale-parity.mjs --guard",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && pnpm exec changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-i18next": "6.1.4",
    "prettier": "3.8.3",
    "turbo": "2.9.7",
    "typescript": "6.0.3"
  }
}
