+    // Serves Expo DOM component bundles over the secure https://appassets.androidplatform.net
+    // origin (mapped to android_asset) so React can mount in release builds. The bundle URL is
+    // rewritten from file:///android_asset/www.bundle/... to this origin in RNCWebViewManagerImpl.
+    // Other (non-appassets) requests fall through untouched, so non-DOM WebViews are unaffected.
+    private WebViewAssetLoader assetLoader;
+
+    @Override
+    public WebResourceResponse shouldInterceptRequest(WebView view, WebResourceRequest request) {
+        if (assetLoader == null) {
+            assetLoader = new WebViewAssetLoader.Builder()
+                .addPathHandler("/assets/", new WebViewAssetLoader.AssetsPathHandler(view.getContext().getApplicationContext()))
+                .build();
+        }
+        WebResourceResponse response = assetLoader.shouldInterceptRequest(request.getUrl());
+        if (response != null) {
+            return response;
+        }
+        return super.shouldInterceptRequest(view, request);
+    }
